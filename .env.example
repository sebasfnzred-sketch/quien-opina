# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and must NEVER be committed.

# ── InsForge ──────────────────────────────────────────────────────────────────
# Server-only (no NEXT_PUBLIC_ prefix — never exposed to the browser).
# Get your URL from: .insforge/project.json → "oss_host" field
#   npx @insforge/cli link        (link an existing project)
#   npx @insforge/cli create      (create a new project)
# Get your anon key:
#   npx @insforge/cli secrets get ANON_KEY
INSFORGE_URL=https://your-project.us-east.insforge.app
INSFORGE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# ── NewsAPI ───────────────────────────────────────────────────────────────────
# Free plan: 100 requests/day, English articles only.
# Register at: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Used server-side to classify mentions with claude-haiku.
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
